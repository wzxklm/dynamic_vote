# ===== 必填 =====

# 数据库密码（用于 Docker Compose 内部 PostgreSQL）
DB_PASSWORD=your_secure_password

# AI 服务（Google AI Studio 官方 API）
AI_API_KEY=your_google_ai_studio_api_key

# ===== 可选（有默认值）=====

# AI 模型
AI_MODEL_LIGHT=gemini-flash-latest     # 动态选项匹配（轻量快速）
AI_MODEL_FULL=gemini-pro-latest        # 分析报告生成（完整能力）

# IP 查询备用源 Token
IP_API_FALLBACK_TOKEN=

# 速率限制
RATE_LIMIT_VOTE_PER_HOUR=10
RATE_LIMIT_IP_LOOKUP_PER_MINUTE=40
RATE_LIMIT_REPORT_PER_HOUR=3

# 站点 URL（用于 SEO 和分享链接）
NEXT_PUBLIC_SITE_URL=http://localhost:3000
